rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // For production apps, it's better to use custom claims for admin roles.
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }
    
    // Publicly readable collections
    match /lotteryEvents/{lotteryEventId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }
    match /announcements/{announcementId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }
    match /settings/{settingsId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // User data
    match /users/{userId} {
      // Admins can list all users and get any individual user.
      // Owners can only get/write their own document.
      allow read: if isAdmin();
      allow get: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // User sub-collections
    match /users/{userId}/wallets/{walletId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/lotteryNumbers/{lotteryNumberId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Admin collection group queries
    match /{path=**}/transactions/{transaction} {
      allow read: if isAdmin();
    }
    match /{path=**}/lotteryNumbers/{lotteryNumberId} {
      allow read: if isAdmin();
    }
  }
}
