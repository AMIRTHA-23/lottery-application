rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: TEMPORARY DEBUGGING RULE
    // The following rule makes your entire database readable by any client.
    // This is NOT secure and is intended only to diagnose the persistent
    // permission error. This MUST be secured before any production use.
    match /{document=**} {
      allow read: if true;
    }

    // Secure write rules remain in place.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    match /users/{userId}/{documents=**} {
      allow write: if isOwner(userId);
    }
    
    match /lotteryEvents/{lotteryEventId} {
      allow write: if isAdmin();
    }
    
    match /announcements/{announcementId} {
      allow write: if isAdmin();
    }
  }
}
