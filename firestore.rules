rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: TEMPORARY DEBUGGING RULE
    // The following rule makes your entire database readable by any client.
    // This is NOT secure and is intended only to diagnose the persistent
    // permission error. This MUST be secured before any production use.
    match /{document=**} {
      allow read: if true;
    }

    // -------------------------------------------------------------------------
    // Helper Functions for Secure Writes
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@example.com';
    }

    // -------------------------------------------------------------------------
    // Secure Write Rules
    // -------------------------------------------------------------------------

    // Users can write to any document within their own user path.
    match /users/{userId}/{documents=**} {
      allow write: if isOwner(userId);
    }
    
    // Admins can write to lottery events.
    match /lotteryEvents/{lotteryEventId} {
      allow write: if isAdmin();
    }
    
    // Admins can write to announcements.
    match /announcements/{announcementId} {
      allow write: if isAdmin();
    }
  }
}
