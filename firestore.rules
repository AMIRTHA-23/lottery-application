rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // For production apps, it's better to use custom claims for admin roles.
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    // User data is private and only accessible by the owner.
    match /users/{userId}/{documents=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Lottery Events are readable by any authenticated user, but only writable by admins.
    match /lotteryEvents/{lotteryEventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Announcements are readable by any authenticated user, but only writable by admins.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Settings are readable by any authenticated user, but only writable by admins.
    match /settings/{settingsId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
  }
}
