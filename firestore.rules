rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // For production apps, it's better to use custom claims for admin roles.
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    // Collection Group Queries for Admins
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }
    match /{path=**}/lotteryNumbers/{lotteryNumberId} {
      allow list: if isAdmin();
    }

    // Top-level Collections
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(userId);
    }
    
    match /lotteryEvents/{lotteryEventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /settings/{settingsId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }

    // User Sub-collections
    match /users/{userId}/wallets/{walletId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/lotteryNumbers/{lotteryNumberId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
