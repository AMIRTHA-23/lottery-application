rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Core check for administrator role
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES ---
    // These are required for the Admin Dashboard and Reports to query across all users.
    match /{path=**}/transactions/{transactionId} {
      allow read: if isAdmin();
    }
    match /{path=**}/lotteryNumbers/{lotteryNumberId} {
      allow read: if isAdmin();
    }
    match /{path=**}/wallets/{walletId} {
      allow read: if isAdmin();
    }

    // --- GLOBAL ADMIN ACCESS ---
    // Grating full access to admins for any standard document path.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- PUBLIC & AUTHENTICATED ACCESS ---
    match /lotteryEvents/{lotteryEventId} {
      allow read: if request.auth != null;
    }
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
    }
    match /settings/{settingsId} {
      allow read: if request.auth != null;
    }

    // --- USER OWNERSHIP RULES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /wallets/{walletId} {
        allow read, write: if isOwner(userId);
        
        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      match /lotteryNumbers/{lotteryNumberId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}