{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the SMSWIN Lottery app.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user.",
          "format": "uuid"
        },
        "username": {
          "type": "string",
          "description": "The full name of the user."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number of the user."
        },
        "dob": {
          "type": "string",
          "description": "The user's date of birth.",
          "format": "date"
        },
        "gender": {
          "type": "string",
          "description": "The user's gender.",
          "enum": ["male", "female", "other", "prefer-not-to-say"]
        },
        "referralSource": {
          "type": "string",
          "description": "How the user heard about the app."
        },
        "isAgeVerified": {
          "type": "boolean",
          "description": "Whether the user has confirmed they are over 18."
        },
        "kycStatus": {
          "type": "string",
          "description": "Current verification status.",
          "enum": ["Not Submitted", "Pending", "Verified", "Rejected"]
        },
        "registrationDate": {
          "type": "string",
          "description": "The date the user registered.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Account status.",
          "enum": ["Active", "Frozen"]
        }
      },
      "required": [
        "id",
        "username",
        "firstName",
        "lastName",
        "email",
        "registrationDate",
        "dob",
        "gender",
        "isAgeVerified",
        "kycStatus"
      ]
    },
    "Wallet": {
      "title": "Wallet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "specialCoins": { "type": "number", "description": "Redeemable reward coins." },
        "totalCoinsEarned": { "type": "number", "description": "Lifetime reward coins for level calculation." },
        "level": { "type": "number", "description": "User's reward level." }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/users/{userId}/wallets/{walletId}": {
      "schema": {
        "$ref": "#/entities/Wallet"
      },
      "description": "User wallet with reward details."
    }
  }
}
