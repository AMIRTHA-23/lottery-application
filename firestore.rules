rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // For production apps, it's better to use custom claims for admin roles.
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    // This rule allows admins to perform collection group queries across all 'transactions' collections.
    // This is required for the admin dashboard analytics to function correctly.
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }

    // This rule allows admins to query across all 'lotteryNumbers' collections to find winners for payouts.
    match /{path=**}/lotteryNumbers/{lotteryNumberId} {
      allow list: if isAdmin();
    }

    // User data is private, but readable by admins for management purposes.
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Admins can list users for the user management page.
      allow write: if isOwner(userId);
    }
    
    // Rules for user sub-collections (wallets, transactions, etc.)
    match /users/{userId}/{documents=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Lottery Events are readable by any authenticated user, but only writable by admins.
    match /lotteryEvents/{lotteryEventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Announcements are readable by any authenticated user, but only writable by admins.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Settings are readable by any authenticated user, but only writable by admins.
    match /settings/{settingsId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
  }
}
