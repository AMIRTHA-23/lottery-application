rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Core check for administrator role
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // GLOBAL ADMIN READ - Crucial for collection group queries and analytics
    match /{document=**} {
      allow read: if isAdmin();
    }

    // Publicly readable collections
    match /lotteryEvents/{lotteryEventId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }
    match /announcements/{announcementId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }
    match /settings/{settingsId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // User data collections (Access by Owner)
    match /users/{userId} {
      allow get, write: if isOwner(userId);
      
      match /wallets/{walletId} {
        allow read, write: if isOwner(userId);
        
        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      match /lotteryNumbers/{lotteryNumberId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}