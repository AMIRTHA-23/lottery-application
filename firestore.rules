rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // For production apps, it's better to use custom claims for admin roles.
      return request.auth != null && request.auth.token.email == 'admin@example.com';
    }

    // --- ADMIN GLOBAL READ ACCESS ---
    // This rule gives admins read-only access to the entire database.
    // It's a simple and secure way to ensure all admin-side data fetching,
    // including collection group queries for analytics, will work without issue.
    match /{document=**} {
      allow read: if isAdmin();
    }

    // --- PUBLIC/USER-SPECIFIC RULES ---
    
    // Public collections (any authenticated user can read)
    match /lotteryEvents/{lotteryEventId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin(); // But only admins can write
    }
    match /announcements/{announcementId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }
    match /settings/{settingsId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // User-specific data
    match /users/{userId} {
      // A user can read and write to their own profile document.
      // Admin read is covered by the global rule. Admin write is handled below.
      allow get, write: if isOwner(userId);
    }

    match /users/{userId}/wallets/{walletId} {
      // Owner can read/write. Admin can also write for adjustments.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      // Owner can read/write. Admin can also write for adjustments.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/lotteryNumbers/{lotteryNumberId} {
      // Owner can read/write. Admin can also write.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
